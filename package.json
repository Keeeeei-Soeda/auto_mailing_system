    "draft": "node create-zoom-mail.mjs",
    "draft:dry-run": "node create-zoom-mail.mjs --dry-run",
    "draft:test": "node create-zoom-mail.mjs --test"
  },
  "type": "module",
  "bugs": {
    "url": "https://github.com/Keeeeei-Soeda/auto_mailing_system/issues"
  },
  "homepage": "https://github.com/Keeeeei-Soeda/auto_mailing_system#readme",
  "dependencies": {
    "googleapis": "^173.0.0"
  }
